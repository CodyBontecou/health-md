default_platform(:ios)

APP_ID = "com.codybontecou.obsidianhealth"
API_KEY_ID = "T7KGDK4Y4V"
API_ISSUER_ID = "6c3b3640-c6bf-40a9-b6e5-57cda2c7776e"
API_KEY_PATH = "/Users/codybontecou/.private_keys/AuthKey_T7KGDK4Y4V.p8"
APP_VERSION = "1.7.5"

def connect_api_key
  app_store_connect_api_key(
    key_id: API_KEY_ID,
    issuer_id: API_ISSUER_ID,
    key_filepath: API_KEY_PATH,
    in_house: false
  )
end

platform :ios do
  desc "Show current iOS app info on App Store Connect"
  lane :info do
    connect_api_key
    app = Spaceship::ConnectAPI::App.find(APP_ID)
    UI.message("App: #{app.name} (#{app.bundle_id})")
    edit = app.get_edit_app_store_version(platform: Spaceship::ConnectAPI::Platform::IOS)
    if edit
      UI.message("Edit version: #{edit.version_string} — state: #{edit.app_store_state}")
    else
      UI.message("No edit version found")
    end
    live = app.get_live_app_store_version(platform: Spaceship::ConnectAPI::Platform::IOS)
    UI.message("Live version: #{live.version_string} — state: #{live.app_store_state}") if live
  end

  desc "Upload metadata only (iOS)"
  lane :upload_metadata do
    connect_api_key
    deliver(
      app_identifier: APP_ID,
      app_version: APP_VERSION,
      skip_binary_upload: true,
      skip_screenshots: true,
      run_precheck_before_submit: false,
      force: true,
      platform: "ios"
    )
  end

  desc "Upload screenshots only (iOS)"
  lane :upload_screenshots do
    connect_api_key
    deliver(
      app_identifier: APP_ID,
      app_version: APP_VERSION,
      skip_binary_upload: true,
      skip_metadata: true,
      overwrite_screenshots: true,
      run_precheck_before_submit: false,
      force: true,
      platform: "ios"
    )
  end

  desc "Upload metadata + screenshots (iOS)"
  lane :upload_all do
    connect_api_key
    deliver(
      app_identifier: APP_ID,
      app_version: APP_VERSION,
      skip_binary_upload: true,
      overwrite_screenshots: true,
      run_precheck_before_submit: false,
      force: true,
      platform: "ios"
    )
  end

  desc "Submit for review (iOS)"
  lane :submit do
    connect_api_key
    deliver(
      app_identifier: APP_ID,
      app_version: APP_VERSION,
      skip_binary_upload: true,
      skip_screenshots: true,
      run_precheck_before_submit: false,
      submit_for_review: true,
      automatic_release: true,
      force: true,
      platform: "ios",
      submission_information: {
        add_id_info_uses_idfa: false,
        export_compliance_uses_encryption: false,
        export_compliance_is_exempt: true
      }
    )
  end
end

