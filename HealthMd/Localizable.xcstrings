    "Suggested metrics include mood, symptoms, workouts, blood pressure, and blood glucose.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Vorgeschlagene Metriken umfassen Stimmung, Symptome, Trainings, Blutdruck und Blutzucker."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Suggested metrics include mood, symptoms, workouts, blood pressure, and blood glucose."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las métricas sugeridas incluyen estado de ánimo, síntomas, entrenamientos, presión arterial y glucosa en sangre."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
