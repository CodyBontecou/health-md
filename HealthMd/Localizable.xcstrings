    "Failed to export health data. Please check your settings.": {
      "comment": "Generic export failure message",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Export der Gesundheitsdaten fehlgeschlagen. Bitte überprüfen Sie Ihre Einstellungen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Error al exportar datos de salud. Por favor, revisa tus ajustes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Échec de l'exportation des données de santé. Veuillez vérifier vos réglages."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Esportazione dei dati sanitari non riuscita. Controlla le impostazioni."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ヘルスデータのエクスポートに失敗しました。設定を確認してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "건강 데이터를 내보내지 못했습니다. 설정을 확인하세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Gezondheidsgegevens exporteren mislukt. Controleer je instellingen."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Falha ao exportar dados de saúde. Verifique suas configurações."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "健康数据导出失败。请检查您的设置。"
          }
        }
      }
    },
    "Failed to fetch data from HealthKit. Check that health permissions are granted in the Health app.": {
      "comment": "Detailed error: HealthKit error",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Daten konnten nicht von HealthKit abgerufen werden. Überprüfen Sie, ob die Gesundheitsberechtigungen in der Health-App erteilt sind."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Error al obtener datos de HealthKit. Verifica que los permisos de salud estén otorgados en la app Salud."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Échec de la récupération des données depuis HealthKit. Vérifiez que les autorisations de santé sont accordées dans l'app Santé."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Recupero dati da HealthKit non riuscito. Verifica che i permessi sanitari siano concessi nell'app Salute."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "HealthKitからのデータ取得に失敗しました。ヘルスケアAppでヘルス権限が付与されていることを確認してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "HealthKit에서 데이터를 가져오지 못했습니다. 건강 앱에서 권한이 부여되었는지 확인하세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Gegevens ophalen uit HealthKit mislukt. Controleer of gezondheidsmachtigingen zijn verleend in de Gezondheid-app."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Falha ao obter dados do HealthKit. Verifique se as permissões de saúde foram concedidas no app Saúde."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
