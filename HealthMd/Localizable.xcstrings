    "This will remove all health data cached on this Mac. You can re-sync from your iPhone at any time.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This will remove all health data cached on this Mac. You can re-sync from your iPhone at any time."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto eliminará todos los datos de salud almacenados en caché en este Mac. Puedes volver a sincronizar desde tu iPhone en cualquier momento."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela supprimera toutes les données de santé mises en cache sur ce Mac. Vous pouvez resynchroniser depuis votre iPhone à tout moment."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Hiermit werden alle auf diesem Mac zwischengespeicherten Gesundheitsdaten entfernt. Sie können jederzeit erneut von Ihrem iPhone synchronisieren."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo rimuoverà tutti i dati sanitari memorizzati su questo Mac. Puoi sincronizzare nuovamente dal tuo iPhone in qualsiasi momento."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Isso removerá todos os dados de saúde armazenados em cache neste Mac. Você pode sincronizar novamente pelo seu iPhone a qualquer momento."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dit verwijdert alle gezondheidsgegevens die op deze Mac zijn opgeslagen. Je kunt op elk moment opnieuw synchroniseren vanaf je iPhone."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このMacにキャッシュされたすべてのヘルスデータが削除されます。iPhoneからいつでも再同期できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 Mac에 캐시된 모든 건강 데이터가 삭제됩니다. 언제든지 iPhone에서 다시 동기화할 수 있습니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这将删除缓存在此 Mac 上的所有健康数据。您可以随时从 iPhone 重新同步。"
          }
        }
      }
    },
    "Make sure Health.md is open on your iPhone with sync enabled.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Make sure Health.md is open on your iPhone with sync enabled."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Asegúrate de que Health.md esté abierto en tu iPhone con la sincronización activada."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Assurez-vous que Health.md est ouvert sur votre iPhone avec la synchronisation activée."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Stellen Sie sicher, dass Health.md auf Ihrem iPhone geöffnet ist und die Synchronisierung aktiviert ist."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Assicurati che Health.md sia aperto sul tuo iPhone con la sincronizzazione attivata."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Certifique-se de que o Health.md esteja aberto no seu iPhone com a sincronização ativada."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zorg dat Health.md geopend is op je iPhone met synchronisatie ingeschakeld."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "iPhoneでHealth.mdが開いていて、同期が有効になっていることを確認してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "iPhone에서 Health.md가 동기화 활성화 상태로 열려 있는지 확인하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请确保 iPhone 上已打开 Health.md 并启用了同步。"
          }
        }
      }
    },
