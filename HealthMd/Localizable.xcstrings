    "No health data or personal information is included — only app version and system info.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No health data or personal information is included — only app version and system info."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se incluyen datos de salud ni información personal — solo la versión de la aplicación e información del sistema."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aucune donnée de santé ni information personnelle n'est incluse — uniquement la version de l'app et les informations système."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Es werden keine Gesundheitsdaten oder persönlichen Informationen übermittelt — nur App-Version und Systeminformationen."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Nessun dato sanitario o informazione personale è incluso — solo la versione dell'app e le informazioni di sistema."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Nenhum dado de saúde ou informação pessoal é incluído — apenas versão do app e informações do sistema."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Er worden geen gezondheidsgegevens of persoonlijke informatie meegestuurd — alleen appversie en systeeminformatie."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ヘルスデータや個人情報は含まれません — アプリのバージョンとシステム情報のみです。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "건강 데이터나 개인 정보는 포함되지 않으며 앱 버전과 시스템 정보만 포함됩니다."
