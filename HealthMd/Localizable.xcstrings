    "Suggested metrics include mood, symptoms, workouts, blood pressure, and blood glucose.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Suggested metrics include mood, symptoms, workouts, blood pressure, and blood glucose."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las métricas sugeridas incluyen estado de ánimo, síntomas, entrenamientos, presión arterial y glucosa en sangre."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les indicateurs suggérés comprennent l'humeur, les symptômes, les entraînements, la pression artérielle et la glycémie."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Vorgeschlagene Metriken umfassen Stimmung, Symptome, Trainings, Blutdruck und Blutzucker."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le metriche suggerite includono umore, sintomi, allenamenti, pressione sanguigna e glicemia."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "As métricas sugeridas incluem humor, sintomas, exercícios, pressão arterial e glicemia."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Voorgestelde meetwaarden zijn onder andere stemming, symptomen, workouts, bloeddruk en bloedglucose."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "推奨される指標には、気分、症状、ワークアウト、血圧、血糖値が含まれます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "추천 항목에는 기분, 증상, 운동, 혈압 및 혈당이 포함됩니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "推荐的指标包括情绪、症状、锻炼、血压和血糖。"
          }
        }
      }
    },
    "Only categories with enabled metrics in your export settings are shown. Enable more metrics in Health Metrics settings.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Only categories with enabled metrics in your export settings are shown. Enable more metrics in Health Metrics settings."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Solo se muestran las categorías con métricas activadas en tus ajustes de exportación. Activa más métricas en los ajustes de Métricas de salud."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Seules les catégories avec des indicateurs activés dans vos paramètres d'exportation sont affichées. Activez plus d'indicateurs dans les réglages des indicateurs de santé."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Es werden nur Kategorien mit aktivierten Metriken in Ihren Exporteinstellungen angezeigt. Aktivieren Sie weitere Metriken in den Gesundheitsmetriken-Einstellungen."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Vengono mostrate solo le categorie con metriche abilitate nelle impostazioni di esportazione. Abilita più metriche nelle impostazioni Metriche Sanitarie."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Apenas categorias com métricas ativadas nas suas configurações de exportação são exibidas. Ative mais métricas nas configurações de Métricas de Saúde."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Alleen categorieën met ingeschakelde meetwaarden in je exportinstellingen worden getoond. Schakel meer meetwaarden in via Gezondheidsmeetwaarden-instellingen."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "エクスポート設定で有効な指標があるカテゴリのみ表示されます。ヘルス指標設定でより多くの指標を有効にしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "내보내기 설정에서 활성화된 항목이 있는 카테고리만 표시됩니다. 건강 항목 설정에서 더 많은 항목을 활성화하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "仅显示在导出设置中已启用指标的类别。可在健康指标设置中启用更多指标。"
          }
        }
      }
    },
