    "Optimized for Obsidian Bases. All metrics are stored as frontmatter properties for querying, filtering, and sorting.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Optimized for Obsidian Bases. All metrics are stored as frontmatter properties for querying, filtering, and sorting."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Optimiert für Obsidian Bases. Alle Metriken werden als Frontmatter-Eigenschaften zum Abfragen, Filtern und Sortieren gespeichert."
          }
        },
        "es": {
          "stringUnit": {
