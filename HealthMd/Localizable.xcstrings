    "Choose from %lld categories including sleep, activity, heart, nutrition, symptoms, and more. Over 100+ metrics available.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wählen Sie aus %lld Kategorien, darunter Schlaf, Aktivität, Herz, Ernährung, Symptome und mehr. Über 100 Metriken verfügbar."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige entre %lld categorías incluyendo sueño, actividad, corazón, nutrición, síntomas y más. Más de 100 métricas disponibles."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez parmi %lld catégories incluant sommeil, activité, cœur, nutrition, symptômes et plus. Plus de 100 métriques disponibles."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scegli tra %lld categorie tra cui sonno, attività, cuore, nutrizione, sintomi e altro. Oltre 100 metriche disponibili."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%lldカテゴリから選択可能。睡眠、アクティビティ、心臓、栄養、症状などを含み、100以上の指標が利用できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "수면, 활동, 심장, 영양, 증상 등 %lld개 카테고리에서 선택하세요. 100개 이상의 항목을 사용할 수 있습니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kies uit %lld categorieën waaronder slaap, activiteit, hart, voeding, symptomen en meer. Meer dan 100 meetwaarden beschikbaar."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Escolha entre %lld categorias incluindo sono, atividade, coração, nutrição, sintomas e mais. Mais de 100 métricas disponíveis."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "从 %lld 个类别中选择，包括睡眠、活动、心脏、营养、症状等。超过 100 多个指标可用。"
          }
        }
      }
    },
