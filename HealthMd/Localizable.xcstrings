    "Health.md for macOS promotion. Now on macOS, get the desktop app.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Health.md für macOS Werbung. Jetzt auf macOS, holen Sie sich die Desktop-App."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Promoción de Health.md para macOS. Ahora en macOS, obtén la app de escritorio."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Promotion Health.md pour macOS. Maintenant sur macOS, obtenez l'app de bureau."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Promozione Health.md per macOS. Ora su macOS, scarica l'app desktop."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Health.md for macOSのプロモーション。macOS版が登場、デスクトップアプリを入手しましょう。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS용 Health.md 홍보. macOS 출시, 데스크톱 앱을 다운로드하세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Health.md voor macOS-promotie. Nu op macOS, download de desktop-app."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Promoção do Health.md para macOS. Agora no macOS, obtenha o app para desktop."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Health.md macOS 版推广。现已登陆 macOS，获取桌面应用。"
          }
        }
      }
    },
    "Health.md reads your Apple Health data locally on this device.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Health.md liest Ihre Apple Health-Daten lokal auf diesem Gerät."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Health.md reads your Apple Health data locally on this device."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Health.md lee tus datos de Apple Health localmente en este dispositivo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Health.md lit vos données Apple Health localement sur cet appareil."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Health.md legge i tuoi dati di Apple Health localmente su questo dispositivo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Health.mdはこのデバイス上でローカルにApple Healthデータを読み取ります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Health.md는 이 기기에서 로컬로 Apple Health 데이터를 읽습니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Health.md leest je Apple Health-gegevens lokaal op dit apparaat."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Health.md lê seus dados do Apple Health localmente neste dispositivo."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Health.md 在此设备上本地读取您的 Apple Health 数据。"
          }
        }
      }
    },
    "Health.md will automatically export your health data on the schedule below.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Health.md exportiert Ihre Gesundheitsdaten automatisch gemäß dem folgenden Zeitplan."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Health.md will automatically export your health data on the schedule below."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Health.md exportará automáticamente tus datos de salud según la programación a continuación."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Health.md exportera automatiquement vos données de santé selon la planification ci-dessous."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Health.md esporterà automaticamente i tuoi dati sanitari secondo la pianificazione seguente."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Health.mdは以下のスケジュールでヘルスデータを自動的にエクスポートします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Health.md가 아래 예약에 따라 자동으로 건강 데이터를 내보냅니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Health.md exporteert je gezondheidsgegevens automatisch volgens onderstaand schema."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Health.md exportará automaticamente seus dados de saúde conforme o agendamento abaixo."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Health.md 将按照以下计划自动导出您的健康数据。"
          }
        }
      }
    },
