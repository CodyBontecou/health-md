    "When enabled, your Mac can discover this iPhone and request health data over your local network.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When enabled, your Mac can discover this iPhone and request health data over your local network."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuando esté activado, tu Mac podrá descubrir este iPhone y solicitar datos de salud a través de tu red local."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorsque cette option est activée, votre Mac peut détecter cet iPhone et demander des données de santé via votre réseau local."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn aktiviert, kann Ihr Mac dieses iPhone erkennen und Gesundheitsdaten über Ihr lokales Netzwerk anfordern."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando attivato, il tuo Mac può rilevare questo iPhone e richiedere i dati sanitari tramite la rete locale."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando ativado, seu Mac pode descobrir este iPhone e solicitar dados de saúde pela sua rede local."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wanneer ingeschakeld kan je Mac deze iPhone vinden en gezondheidsgegevens opvragen via je lokale netwerk."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "有効にすると、MacがこのiPhoneをローカルネットワーク上で検出し、ヘルスデータをリクエストできます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "활성화하면 Mac이 로컬 네트워크를 통해 이 iPhone을 찾고 건강 데이터를 요청할 수 있습니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "启用后，您的 Mac 可以在本地网络中发现此 iPhone 并请求健康数据。"
          }
        }
      }
    },
