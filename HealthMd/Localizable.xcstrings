    "When enabled, automatically sends data to Mac after each export" : {

    },
    "When enabled, selected metrics will create individual timestamped files in addition to daily summaries." : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn aktiviert, werden für ausgewählte Metriken zusätzlich zu den Tageszusammenfassungen einzelne Dateien mit Zeitstempel erstellt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "When enabled, selected metrics will create individual timestamped files in addition to daily summaries."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cuando esté activado, las métricas seleccionadas crearán archivos individuales con marca de tiempo además de los resúmenes diarios."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lorsque cette option est activée, les indicateurs sélectionnés créeront des fichiers horodatés individuels en complément des résumés quotidiens."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quando attivato, le metriche selezionate creeranno file individuali con marca temporale in aggiunta ai riepiloghi giornalieri."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "有効にすると、選択した指標のタイムスタンプ付き個別ファイルが日次サマリーに加えて作成されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "활성화하면 선택한 항목이 일일 요약 외에 개별 타임스탬프 파일을 생성합니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wanneer ingeschakeld maken geselecteerde meetwaarden individuele bestanden met tijdstempel aan naast dagelijkse samenvattingen."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quando ativado, as métricas selecionadas criarão arquivos individuais com data/hora além dos resumos diários."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "启用后，所选指标将在每日摘要之外创建单独的带时间戳文件。"
          }
        }
      }
    },
    "When enabled, your Mac can discover this iPad and request health data over your local network." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn aktiviert, kann Ihr Mac dieses iPad erkennen und Gesundheitsdaten über Ihr lokales Netzwerk anfordern."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "When enabled, your Mac can discover this iPad and request health data over your local network."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cuando esté activado, tu Mac podrá descubrir este iPad y solicitar datos de salud a través de tu red local."
          }
