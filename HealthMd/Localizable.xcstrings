    "Step 1 of 2: Enable this toggle to activate individual entry tracking.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Schritt 1 von 2: Aktivieren Sie diesen Schalter, um die individuelle Eintragserfassung zu aktivieren."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Paso 1 de 2: Activa este interruptor para habilitar el seguimiento de entradas individuales."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Étape 1 sur 2 : Activez ce commutateur pour activer le suivi individuel des entrées."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Passaggio 1 di 2: Abilita questo interruttore per attivare il monitoraggio delle voci individuali."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ステップ1/2：このトグルを有効にして個別エントリトラッキングを開始します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "2단계 중 1단계: 이 토글을 활성화하여 개별 항목 추적을 시작하세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Stap 1 van 2: schakel deze optie in om individueel bijhouden te activeren."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Passo 1 de 2: Ative este controle para ativar o rastreamento de entrada individual."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "第 1 步（共 2 步）：启用此开关以激活单条记录追踪。"
          }
        }
      }
    },
    "Step 2 of 2: Select specific metrics below to track individually.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Schritt 2 von 2: Wählen Sie unten bestimmte Metriken zur individuellen Erfassung aus."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Paso 2 de 2: Selecciona métricas específicas a continuación para rastrear individualmente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Étape 2 sur 2 : Sélectionnez des métriques spécifiques ci-dessous pour les suivre individuellement."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Passaggio 2 di 2: Seleziona le metriche specifiche qui sotto da monitorare individualmente."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ステップ2/2：以下から個別に追跡する指標を選択してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "2단계 중 2단계: 아래에서 개별 추적할 항목을 선택하세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
