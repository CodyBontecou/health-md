    "Health data is protected while your device is locked. The export will retry automatically when your device is unlocked.": {
      "comment": "Detailed error: device locked",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Gesundheitsdaten sind geschützt, solange Ihr Gerät gesperrt ist. Der Export wird automatisch wiederholt, wenn Ihr Gerät entsperrt ist."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los datos de salud están protegidos mientras tu dispositivo está bloqueado. La exportación se reintentará automáticamente cuando tu dispositivo se desbloquee."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les données de santé sont protégées lorsque votre appareil est verrouillé. L'exportation réessaiera automatiquement lorsque votre appareil sera déverrouillé."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I dati sanitari sono protetti quando il dispositivo è bloccato. L'esportazione verrà riprovata automaticamente quando il dispositivo sarà sbloccato."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "デバイスがロック中はヘルスデータが保護されています。デバイスのロックが解除されると、エクスポートが自動的に再試行されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "기기가 잠겨 있는 동안 건강 데이터가 보호됩니다. 기기가 잠금 해제되면 내보내기가 자동으로 재시도됩니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Gezondheidsgegevens zijn beveiligd terwijl je apparaat vergrendeld is. De export wordt automatisch opnieuw geprobeerd wanneer je apparaat ontgrendeld is."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Os dados de saúde são protegidos enquanto o dispositivo está bloqueado. A exportação será tentada novamente automaticamente quando o dispositivo for desbloqueado."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "设备锁定时健康数据受到保护。设备解锁后将自动重试导出。"
          }
        }
      }
    },
