    "Add fields that export with empty values for manual entry (e.g., omron_systolic, omron_diastolic)": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add fields that export with empty values for manual entry (e.g., omron_systolic, omron_diastolic)"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Añade campos que se exporten con valores vacíos para entrada manual (ej., omron_systolic, omron_diastolic)"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajouter des champs exportés avec des valeurs vides pour une saisie manuelle (p. ex., omron_systolic, omron_diastolic)"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Felder mit leeren Werten für manuelle Eingabe hinzufügen (z. B. omron_systolic, omron_diastolic)"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Aggiungi campi che vengono esportati con valori vuoti per l'inserimento manuale (es. omron_systolic, omron_diastolic)"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Adicionar campos que exportam com valores vazios para preenchimento manual (ex.: omron_systolic, omron_diastolic)"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Voeg velden toe die met lege waarden worden geëxporteerd voor handmatige invoer (bijv. omron_systolic, omron_diastolic)"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "手動入力用の空の値でエクスポートされるフィールドを追加します（例：omron_systolic、omron_diastolic）"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "수동 입력을 위해 빈 값으로 내보내는 필드 추가 (예: omron_systolic, omron_diastolic)"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "添加导出时值为空的字段，以供手动输入（例如 omron_systolic、omron_diastolic）"
          }
        }
      }
    },
