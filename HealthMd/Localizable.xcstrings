    "All Time will sync every day of health data. This may take several minutes." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bei „Gesamter Zeitraum“ werden alle Gesundheitsdaten synchronisiert. Dies kann einige Minuten dauern."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "All Time will sync every day of health data. This may take several minutes."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Todo el historial sincronizará cada día de datos de salud. Esto puede tardar varios minutos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La synchronisation complète inclura chaque jour de données de santé. Cela peut prendre plusieurs minutes."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tutto il periodo sincronizzerà ogni giorno di dati sanitari. Potrebbe richiedere diversi minuti."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "全期間を選択すると、すべてのヘルスデータを同期します。数分かかる場合があります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "전체 기간은 모든 건강 데이터를 동기화합니다. 몇 분 정도 걸릴 수 있습니다."
          }
        },
