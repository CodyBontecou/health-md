    "Only categories with enabled metrics in your export settings are shown. Enable more metrics in Health Metrics settings." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Es werden nur Kategorien mit aktivierten Metriken in Ihren Exporteinstellungen angezeigt. Aktivieren Sie weitere Metriken in den Gesundheitsmetriken-Einstellungen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Only categories with enabled metrics in your export settings are shown. Enable more metrics in Health Metrics settings."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Solo se muestran las categorías con métricas activadas en tus ajustes de exportación. Activa más métricas en los ajustes de Métricas de salud."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seules les catégories avec des indicateurs activés dans vos paramètres d'exportation sont affichées. Activez plus d'indicateurs dans les réglages des indicateurs de santé."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vengono mostrate solo le categorie con metriche abilitate nelle impostazioni di esportazione. Abilita più metriche nelle impostazioni Metriche Sanitarie."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "エクスポート設定で有効な指標があるカテゴリのみ表示されます。ヘルス指標設定でより多くの指標を有効にしてください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "내보내기 설정에서 활성화된 항목이 있는 카테고리만 표시됩니다. 건강 항목 설정에서 더 많은 항목을 활성화하세요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alleen categorieën met ingeschakelde meetwaarden in je exportinstellingen worden getoond. Schakel meer meetwaarden in via Gezondheidsmeetwaarden-instellingen."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apenas categorias com métricas ativadas nas suas configurações de exportação são exibidas. Ative mais métricas nas configurações de Métricas de Saúde."
