    "⚠️ No metrics selected — individual entries won't be created until you select metrics to track.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ Keine Metriken ausgewählt — individuelle Einträge werden erst erstellt, wenn Sie Metriken zur Erfassung auswählen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ No hay métricas seleccionadas — no se crearán entradas individuales hasta que selecciones métricas para rastrear."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ Aucune métrique sélectionnée — les entrées individuelles ne seront pas créées tant que vous n'aurez pas sélectionné des métriques à suivre."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ Nessuna metrica selezionata — le voci individuali non verranno create finché non selezioni metriche da monitorare."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ 指標が未選択 — 追跡する指標を選択するまで個別エントリは作成されません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ 선택된 항목 없음 — 추적할 항목을 선택할 때까지 개별 항목이 생성되지 않습니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ Geen meetwaarden geselecteerd — individuele items worden pas aangemaakt als je meetwaarden selecteert om bij te houden."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ Nenhuma métrica selecionada — entradas individuais não serão criadas até que você selecione métricas para rastrear."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ 未选择指标——在您选择要追踪的指标之前，不会创建单条记录。"
          }
        }
      }
    },
