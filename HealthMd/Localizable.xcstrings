    "Could not access the vault folder. You may need to re-select the folder to grant permission.": {
      "comment": "Detailed error: vault access denied",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zugriff auf den Vault-Ordner nicht möglich. Möglicherweise müssen Sie den Ordner erneut auswählen, um die Berechtigung zu erteilen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo acceder a la carpeta de la bóveda. Es posible que necesites volver a seleccionar la carpeta para otorgar permiso."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible d'accéder au dossier du coffre. Vous devrez peut-être resélectionner le dossier pour accorder les permissions."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossibile accedere alla cartella del vault. Potrebbe essere necessario riselezionare la cartella per concedere l'autorizzazione."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Vaultフォルダにアクセスできませんでした。フォルダを再選択して権限を付与する必要がある場合があります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "보관함 폴더에 접근할 수 없습니다. 권한을 부여하려면 폴더를 다시 선택해야 할 수 있습니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kan de kluismap niet openen. Mogelijk moet je de map opnieuw selecteren om toestemming te verlenen."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível acessar a pasta do cofre. Talvez você precise selecionar a pasta novamente para conceder permissão."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法访问知识库文件夹。您可能需要重新选择文件夹以授予权限。"
          }
        }
      }
    },
