    "NSHealthShareUsageDescription": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Health.md reads your health data to export it to your Obsidian vault."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Health.md lee tus datos de salud para exportarlos a tu bóveda de Obsidian."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Health.md lit vos données de santé pour les exporter vers votre coffre Obsidian."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Health.md liest Ihre Gesundheitsdaten, um sie in Ihren Obsidian Vault zu exportieren."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Health.md legge i tuoi dati sanitari per esportarli nel tuo vault Obsidian."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Health.md lê seus dados de saúde para exportá-los para o seu cofre do Obsidian."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Health.md leest je gezondheidsgegevens om ze naar je Obsidian-kluis te exporteren."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Health.mdはヘルスデータを読み取り、Obsidian Vaultにエクスポートします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Health.md는 Obsidian 보관함으로 내보내기 위해 건강 데이터를 읽습니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Health.md 读取您的健康数据，以便将其导出到您的 Obsidian 知识库。"
          }
        }
      }
    },
    "NSHealthUpdateUsageDescription": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Health.md may need to update health data metadata as part of the export process."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Health.md puede necesitar actualizar los metadatos de datos de salud como parte del proceso de exportación."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Health.md peut avoir besoin de mettre à jour les métadonnées de santé dans le cadre du processus d'exportation."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Health.md muss möglicherweise Gesundheitsdaten-Metadaten im Rahmen des Exportvorgangs aktualisieren."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Health.md potrebbe dover aggiornare i metadati dei dati sanitari come parte del processo di esportazione."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Health.md pode precisar atualizar metadados de saúde como parte do processo de exportação."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Health.md moet mogelijk metadata van gezondheidsgegevens bijwerken als onderdeel van het exportproces."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Health.mdはエクスポート処理の一環として、ヘルスデータのメタデータを更新する場合があります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Health.md는 내보내기 과정에서 건강 데이터 메타데이터를 업데이트해야 할 수 있습니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Health.md 可能需要在导出过程中更新健康数据的元信息。"
          }
        }
      }
    },
    "NSLocalNetworkUsageDescription": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Health.md uses your local network to sync health data between your iPhone and Mac."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Health.md usa tu red local para sincronizar datos de salud entre tu iPhone y Mac."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Health.md utilise votre réseau local pour synchroniser les données de santé entre votre iPhone et votre Mac."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Health.md verwendet Ihr lokales Netzwerk, um Gesundheitsdaten zwischen Ihrem iPhone und Mac zu synchronisieren."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Health.md utilizza la rete locale per sincronizzare i dati sanitari tra il tuo iPhone e il Mac."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Health.md usa sua rede local para sincronizar dados de saúde entre seu iPhone e Mac."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Health.md gebruikt je lokale netwerk om gezondheidsgegevens te synchroniseren tussen je iPhone en Mac."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Health.mdはローカルネットワークを使用して、iPhoneとMac間でヘルスデータを同期します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Health.md는 iPhone과 Mac 간에 건강 데이터를 동기화하기 위해 로컬 네트워크를 사용합니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Health.md 使用本地网络在您的 iPhone 和 Mac 之间同步健康数据。"
          }
        }
      }
    }
  },
  "version": "1.0"
}
